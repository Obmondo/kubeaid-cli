apiVersion: v1
kind: Secret
metadata:
  name: cloud-credentials
  namespace: kube-system
  labels:
    kubeaid.io/managed-by: kubeaid
stringData:
{{- if .HetznerConfig }}
  hcloud: {{ .HetznerCredentials.APIToken | quote }}

  {{- /* HCloud Network name — required when the CCM is told to attach
         LBs to a network (values-ccm-hcloud.yaml.tmpl enables
         `networking.network` for VPN clusters and workload-on-VPN).
         The network is named after the cluster (see
         pkg/cloud/hetzner/network.go::EnsureHetznerNetwork). */ -}}
  {{- if or (eq .ClusterConfig.Type "vpn") (and (eq .ClusterConfig.Type "workload") .HetznerConfig.HCloudVPNCluster) }}
  network: {{ .ClusterConfig.Name | quote }}
  {{- end }}

  {{- if or (eq .HetznerConfig.Mode "bare-metal") (eq .HetznerConfig.Mode "hybrid") }}
  robot-user: {{ .HetznerCredentials.Robot.User | quote }}
  robot-password: {{ .HetznerCredentials.Robot.Password | quote }}
  {{- end }}

{{- end }}
