apiVersion: v1
kind: Secret
metadata:
  name: cloud-credentials
  namespace: kube-system
  labels:
    kubeaid.io/managed-by: kubeaid
stringData:
{{- if .HetznerConfig }}
  {{/* hcloud key is required in EVERY Hetzner mode, including pure
       bare-metal: the ccm-hetzner wrapper maps the upstream chart's
       HCLOUD_TOKEN env onto cloud-credentials/hcloud WITHOUT
       optional:true, so a CCM pod (re)started against a secret
       missing the key dies with CreateContainerConfigError — and
       upstream hcloud-cloud-controller-manager initialises its
       HCloud client at startup in Robot mode too. An earlier
       revision gated this line behind hcloud/hybrid on the (wrong)
       assumption bare-metal CCM only reads Robot creds; parser
       validation enforces a non-empty apiToken for every mode, so
       the value is always real. */}}
  hcloud: {{ .HetznerCredentials.APIToken | quote }}

  {{/* HCloud Network name — required when the CCM is told to attach
       LBs to a network (values-ccm-hetzner.yaml.tmpl enables
       `networking.enabled` for VPN clusters and workload-on-VPN).
       The network is named after the cluster (see
       pkg/cloud/hetzner/network.go::EnsureHetznerNetwork). */}}
  {{- if or (eq .ClusterConfig.Type "vpn") (and (eq .ClusterConfig.Type "workload") .HetznerConfig.HCloudVPNCluster) }}
  network: {{ .ClusterConfig.Name | quote }}
  {{- end }}

  {{- if or (eq .HetznerConfig.Mode "bare-metal") (eq .HetznerConfig.Mode "hybrid") }}
  robot-user: {{ .HetznerCredentials.Robot.User | quote }}
  robot-password: {{ .HetznerCredentials.Robot.Password | quote }}
  {{- end }}

{{- end }}
