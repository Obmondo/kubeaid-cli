apiVersion: v1
kind: Secret
metadata:
  name: hetzner-ssh-keypair
  namespace: {{ .CAPIClusterNamespace }}
stringData:
  sshkey-name: {{ .HetznerConfig.SSHKeyPair.Name }}
  ssh-privatekey: |
{{- .HetznerConfig.SSHKeyPair.PrivateKey | nindent 4 }}
  ssh-publickey: {{ .HetznerConfig.SSHKeyPair.PublicKey }}
