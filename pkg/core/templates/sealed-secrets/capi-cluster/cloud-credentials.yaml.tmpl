apiVersion: v1
kind: Secret
metadata:
  name: cloud-credentials
  namespace: {{ .CAPIClusterNamespace }}
  labels:
    kubeaid.io/managed-by: kubeaid
stringData:
{{- if .AWSConfig }}
  AWS_B64ENCODED_CREDENTIALS: {{ .AWSB64EncodedCredentials }}
{{- end }}

{{- if .HetznerConfig }}
  {{- /* hcloud key — only meaningful when the cluster touches HCloud
         (hcloud, hybrid). Pure bare-metal has no HCloud client and the
         CAPH controller reads robot creds for BM-side reconcile. */ -}}
  {{- if or (eq .HetznerConfig.Mode "hcloud") (eq .HetznerConfig.Mode "hybrid") }}
  hcloud: {{ .HetznerCredentials.APIToken | quote }}
  {{- end }}

  {{- if or (eq .HetznerConfig.Mode "bare-metal") (eq .HetznerConfig.Mode "hybrid") }}
  robot-user: {{ .HetznerCredentials.Robot.User | quote }}
  robot-password: {{ .HetznerCredentials.Robot.Password | quote }}
  {{- end }}

{{- end }}
