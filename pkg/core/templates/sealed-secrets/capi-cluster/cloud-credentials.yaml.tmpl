apiVersion: v1
kind: Secret
metadata:
  name: cloud-credentials
  namespace: {{ .CAPIClusterNamespace }}
  labels:
    kubeaid.io/managed-by: kubeaid
stringData:
{{- if .AWSConfig }}
  AWS_B64ENCODED_CREDENTIALS: {{ .AWSB64EncodedCredentials }}
{{- end }}

{{- if .HetznerConfig }}
  {{/* hcloud key is required by CAPH for every mode, including pure
       bare-metal: the controller's HCloud client initialises at
       startup (used for vSwitch attachment, network management, and
       CCM-side LB) and bails with "hcloud token cannot be an empty
       string" if the secret omits the key. Earlier revisions of this
       template gated the hcloud line behind hcloud/hybrid modes and
       a bare-metal HetznerBareMetalMachine reconcile failed hard. */}}
  hcloud: {{ .HetznerCredentials.APIToken | quote }}

  {{- if or (eq .HetznerConfig.Mode "bare-metal") (eq .HetznerConfig.Mode "hybrid") }}
  robot-user: {{ .HetznerCredentials.Robot.User | quote }}
  robot-password: {{ .HetznerCredentials.Robot.Password | quote }}
  {{- end }}

{{- end }}
