apiVersion: v1
kind: Secret
metadata:
  name: repo-kubeaid
  namespace: argocd
  labels:
    argocd.argoproj.io/secret-type: repository

stringData:
  name: kubeaid
  url: {{ .KubeaidFork.URL }}
  type: git
  {{- if not (.KubeaidFork.URL | hasPrefix "http") }}
  sshPrivateKey: |-
{{- .ClusterConfig.ArgoCD.DeployKeys.Kubeaid.PrivateKey | nindent 4 }}
  {{- end }}
