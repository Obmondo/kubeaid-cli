{{- /*
Traefik values overlay for the managed-Keycloak VPN flow.

load-balancer.hetzner.cloud/uses-proxyprotocol MUST be "true": the
kubeaid traefik chart enables --entrypoints.{web,websecure}.proxyprotocol
=true so Traefik reads the real client IP from the PROXY header instead
of seeing every request as coming from the HCloud LB. The HCloud CCM
defaults uses-proxyprotocol off, so the LB would not send that header —
a mismatch makes Traefik reject every connection, breaking external
traffic to keycloak.<dns> / netbird.<dns> and cert-manager's HTTP-01
ACME challenges.
*/ -}}
traefik:
  service:
    annotations:
      load-balancer.hetzner.cloud/network-zone: eu-central
      load-balancer.hetzner.cloud/uses-proxyprotocol: "true"
  providers:
    kubernetesCRD:
      enabled: true
      allowCrossNamespace: true
    kubernetesIngress:
      publishedService:
        enabled: true
  podDisruptionBudget:
    enabled: false
