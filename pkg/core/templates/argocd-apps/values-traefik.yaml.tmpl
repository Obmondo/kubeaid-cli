{{- /*
Traefik values overlay for the managed-Keycloak VPN flow.

load-balancer.hetzner.cloud/uses-proxyprotocol MUST be "true": the
kubeaid traefik chart enables --entrypoints.{web,websecure}.proxyprotocol
=true so Traefik reads the real client IP from the PROXY header instead
of seeing every request as coming from the HCloud LB. The HCloud CCM
defaults uses-proxyprotocol off, so the LB would not send that header —
a mismatch makes Traefik reject every connection, breaking external
traffic to keycloak.<dns> / netbird.<dns> and cert-manager's HTTP-01
ACME challenges.
*/ -}}
traefik:
  service:
    annotations:
      load-balancer.hetzner.cloud/network-zone: eu-central
      load-balancer.hetzner.cloud/uses-proxyprotocol: "true"
  providers:
    kubernetesCRD:
      enabled: true
      allowCrossNamespace: true
    kubernetesIngress:
      publishedService:
        enabled: true
  podDisruptionBudget:
    enabled: false
{{- if .NetBirdAPIKey }}

# Internal Traefik: a second, ClusterIP-only Traefik with its own
# `traefik-internal` IngressClass, for internal / mesh-only domains. It has no
# public HCloud LB — it's reached over the NetBird mesh via the
# netbird-operator networkResource that targets the traefik-internal Service
# (see cluster.netbird.networkResources). Gated on secrets.yaml netbird.apiKey
# being set: without a Mgmt key there's no mesh to expose it on. The instance's
# shape (ClusterIP, ingressClass name, fullnameOverride, replicas) lives in the
# kubeaid traefik chart's traefik-internal defaults; here we only enable it.
traefik-internal:
  enabled: true
{{- end }}
