{{- /*
NetBird Mgmt + Signal + Relay + Dashboard + Coturn values overlay.

Two layers of templating live in this file:

  1. Go-template / kubeaid-cli (this layer): substitutes cluster.{keycloak,netbird}
     fields into the chart values at render time.
  2. NetBird Mgmt's runtime template engine: reads management.json after
     the chart has rendered it, substitutes {{ .ENV_NAME }} placeholders
     from envFromSecret-mounted env vars (the netbird Secret).

Inner {{ .ENV_NAME }} directives are escaped with `{{` `<expr>` `}}` so
Go's template engine emits them verbatim into the rendered YAML.
*/ -}}
global:
  postgresql:
    # Pinned off in kubeaid-cli's overlay so the bootstrap doesn't depend
    # on the cluster's kubeaid chart version carrying the chart-side
    # default. TODO: make this a config toggle when kubeaid-cli grows
    # backup support.
    backups:
      enabled: false

netbird:
  fullnameOverride: netbird

  management:
    configmap: |-
      {
        "Stuns": [
          {
            "Proto": "udp",
            "URI": "{{`{{ .STUN_SERVER }}`}}",
            "Username": "",
            "Password": ""
          }
        ],
        "TURNConfig": {
          "TimeBasedCredentials": false,
          "CredentialsTTL": "12h0m0s",
          "Secret": "secret",
          "Turns": [
            {
              "Proto": "udp",
              "URI": "{{`{{ .TURN_SERVER }}`}}",
              "Username": "{{`{{ .TURN_SERVER_USER }}`}}",
              "Password": "{{`{{ .TURN_SERVER_PASSWORD }}`}}"
            }
          ]
        },
        "Relay": {
          "Addresses": ["rels://{{ .ClusterConfig.NetBird.DNS }}:443/relay"],
          "CredentialsTTL": "24h",
          "Secret": "{{`{{ .RELAY_PASSWORD }}`}}"
        },
        "Signal": {
          "Proto": "https",
          "URI": "{{ .ClusterConfig.NetBird.DNS }}:443",
          "Username": "",
          "Password": ""
        },
        "Datadir": "/var/lib/netbird/",
        "DataStoreEncryptionKey": "{{`{{ .DATASTORE_ENCRYPTION_KEY }}`}}",
        "HttpConfig": {
          "LetsEncryptDomain": "",
          "CertFile": "",
          "CertKey": "",
          "AuthAudience": "{{`{{ .IDP_CLIENT_ID }}`}}",
          "AuthIssuer": "https://{{ .ClusterConfig.Keycloak.DNS }}/realms/{{ .ClusterConfig.Keycloak.Realm }}",
          "AuthUserIDClaim": "",
          "AuthKeysLocation": "https://{{ .ClusterConfig.Keycloak.DNS }}/realms/{{ .ClusterConfig.Keycloak.Realm }}/protocol/openid-connect/certs",
          "OIDCConfigEndpoint": "https://{{ .ClusterConfig.Keycloak.DNS }}/realms/{{ .ClusterConfig.Keycloak.Realm }}/.well-known/openid-configuration",
          "IdpSignKeyRefreshEnabled": false
        },
        "IdpManagerConfig": {
          "ManagerType": "keycloak",
          "ClientConfig": {
            "Issuer": "https://{{ .ClusterConfig.Keycloak.DNS }}/realms/{{ .ClusterConfig.Keycloak.Realm }}/.well-known/openid-configuration",
            "TokenEndpoint": "https://{{ .ClusterConfig.Keycloak.DNS }}/realms/{{ .ClusterConfig.Keycloak.Realm }}/protocol/openid-connect/token",
            "ClientID": "{{`{{ .IDP_CLIENT_MGMT_ID }}`}}",
            "ClientSecret": "{{`{{ .IDP_CLIENT_MGMT_SECRET }}`}}",
            "GrantType": "client_credentials"
          },
          "ExtraConfig": {
            "Password": "{{`{{ .IDP_SERVICE_ACCOUNT_PASSWORD }}`}}",
            "Username": "{{`{{ .IDP_SERVICE_ACCOUNT_USER }}`}}",
            "AdminEndpoint": "https://{{ .ClusterConfig.Keycloak.DNS }}/admin/realms/{{ .ClusterConfig.Keycloak.Realm }}"
          },
          "KeycloakClientCredentials": null
        },
        "DeviceAuthorizationFlow": {
          "Provider": "hosted",
          "ProviderConfig": {
            "ClientID": "{{`{{ .IDP_CLIENT_ID }}`}}",
            "ClientSecret": "",
            "Domain": "{{ .ClusterConfig.Keycloak.DNS }}",
            "Audience": "{{`{{ .IDP_CLIENT_ID }}`}}",
            "TokenEndpoint": "https://{{ .ClusterConfig.Keycloak.DNS }}/realms/{{ .ClusterConfig.Keycloak.Realm }}/protocol/openid-connect/token",
            "DeviceAuthEndpoint": "https://{{ .ClusterConfig.Keycloak.DNS }}/realms/{{ .ClusterConfig.Keycloak.Realm }}/protocol/openid-connect/auth/device",
            "AuthorizationEndpoint": "",
            "Scope": "openid",
            "UseIDToken": false,
            "RedirectURLs": null
          }
        },
        "PKCEAuthorizationFlow": {
          "ProviderConfig": {
            "ClientID": "{{`{{ .IDP_CLIENT_ID }}`}}",
            "ClientSecret": "",
            "Domain": "{{ .ClusterConfig.Keycloak.DNS }}",
            "Audience": "{{`{{ .IDP_CLIENT_ID }}`}}",
            "TokenEndpoint": "https://{{ .ClusterConfig.Keycloak.DNS }}/realms/{{ .ClusterConfig.Keycloak.Realm }}/protocol/openid-connect/token",
            "DeviceAuthEndpoint": "",
            "AuthorizationEndpoint": "",
            "Scope": "openid profile email offline_access api",
            "UseIDToken": false,
            "RedirectURLs": null
          }
        },
        "StoreConfig": {
          "Engine": "postgres"
        },
        "ReverseProxy": {
          "TrustedHTTPProxies": null,
          "TrustedHTTPProxiesCount": 0,
          "TrustedPeers": null
        }
      }

    podCommand:
      args:
        - --port=80
        - --log-file=console
        - --log-level=debug
        - --disable-anonymous-metrics=false
        - --single-account-mode-domain={{ .ClusterConfig.NetBird.DNS }}
        - --dns-domain=netbird.selfhosted

    ingressGrpc:
      enabled: true
      className: traefik
      annotations:
        cert-manager.io/cluster-issuer: letsencrypt-prod
      tls:
        - hosts:
            - {{ .ClusterConfig.NetBird.DNS }}
          secretName: netbird-tls
      hosts:
        - host: {{ .ClusterConfig.NetBird.DNS }}
          paths:
            - path: /management
              pathType: ImplementationSpecific

    ingress:
      enabled: true
      className: traefik
      annotations:
        cert-manager.io/cluster-issuer: letsencrypt-prod
      tls:
        - hosts:
            - {{ .ClusterConfig.NetBird.DNS }}
          secretName: netbird-tls
      hosts:
        - host: {{ .ClusterConfig.NetBird.DNS }}
          paths:
            - path: /api
              pathType: ImplementationSpecific

  signal:
    ingress:
      enabled: true
      className: traefik
      annotations:
        cert-manager.io/cluster-issuer: letsencrypt-prod
      tls:
        - hosts:
            - {{ .ClusterConfig.NetBird.DNS }}
          secretName: netbird-tls
      hosts:
        - host: {{ .ClusterConfig.NetBird.DNS }}
          paths:
            - path: /signalexchange
              pathType: ImplementationSpecific

  relay:
    env:
      NB_LOG_LEVEL: info
      NB_LISTEN_ADDRESS: ":33080"
      NB_EXPOSED_ADDRESS: rels://{{ .ClusterConfig.NetBird.DNS }}:443/relay
    ingress:
      enabled: true
      className: traefik
      annotations:
        cert-manager.io/cluster-issuer: letsencrypt-prod
      tls:
        - hosts:
            - {{ .ClusterConfig.NetBird.DNS }}
          secretName: netbird-tls
      hosts:
        - host: {{ .ClusterConfig.NetBird.DNS }}
          paths:
            - path: /relay
              pathType: ImplementationSpecific

  dashboard:
    enabled: true
    env:
      NETBIRD_MGMT_API_ENDPOINT: https://{{ .ClusterConfig.NetBird.DNS }}:443
      NETBIRD_MGMT_GRPC_API_ENDPOINT: https://{{ .ClusterConfig.NetBird.DNS }}:443
      AUTH_AUTHORITY: https://{{ .ClusterConfig.Keycloak.DNS }}/realms/{{ .ClusterConfig.Keycloak.Realm }}
    ingress:
      enabled: true
      className: traefik
      annotations:
        cert-manager.io/cluster-issuer: letsencrypt-prod
      tls:
        - hosts:
            - {{ .ClusterConfig.NetBird.DNS }}
          secretName: netbird-tls
      hosts:
        - host: {{ .ClusterConfig.NetBird.DNS }}
          paths:
            - path: /
              pathType: ImplementationSpecific

coturn:
  coturn:
    realm: "{{ .ClusterConfig.NetBird.TurnDNS }}"
    auth:
      existingSecret: netbird
      secretKeys:
        username: turnServerUser
        password: turnServerPassword
