{{- /*
The kubeaid chart wraps the upstream operator: `netbird-operator:` is the
subchart; everything else is wrapper values. clusterName derives the router +
proxy names and the chart-created groups k8s-<name> and k8s-<name>-access;
`groups:` lists extra groups this cluster owns (cluster.netbird.groups).
*/ -}}
{{- if .NetBirdOperatorEnabled }}
{{- if .NetBirdManagementURL }}
netbird-operator:
  managementURL: {{ .NetBirdManagementURL | quote }}
{{- end }}
{{- if or .NetBirdRouterEnabled .NetBirdClusterProxyEnabled }}
clusterName: {{ .ClusterConfig.Name | quote }}
{{- end }}
{{- with .NetBird }}
{{- if .Groups }}
groups:
{{- range .Groups }}
  - {{ . | quote }}
{{- end }}
{{- end }}
{{- end }}
{{- if .NetBirdRouterEnabled }}
networkRouter:
  enabled: true
  dnsZone: {{ .NetBird.DNSZone | quote }}
  replicas: 1
networkResources:
  - name: traefik-internal
    namespace: traefik
    service: traefik-internal
{{- end }}
{{- if .NetBirdClusterProxyEnabled }}
clusterProxy:
  enabled: true
{{- with .NetBird.ClusterProxy }}
{{- if gt (len .RBAC) 0 }}
  rbac:
{{- range .RBAC }}
    - group: {{ .Group | quote }}
      clusterRole: {{ .ClusterRole | quote }}
{{- end }}
{{- end }}
{{- end }}
{{- end }}
{{- end }}
