{{- /*
NetBird Kubernetes Operator values overlay.

managementURL points the operator at the parent NetBird Mgmt —
cluster.netbird.dns on VPN clusters (they host Mgmt themselves), the
netbird.<base> Keycloak-DNS convention on workload clusters. Omitting
it is NOT harmless: the operator binary falls back to NetBird Cloud
(api.netbird.io), so when the URL can't be derived this file renders
empty and the operator must be wired manually.

The Mgmt API token deliberately does NOT flow through values — it's
sealed into the netbird/netbird-mgmt-api-key Secret (from secrets.yaml's
netbird.apiKey), which the chart's default netbirdAPI.keyFromSecret
already references. awaitNetBirdOperatorToken gates bootstrap on that
Secret existing.

networkRouter / networkResources / clusterProxy come from
cluster.netbird.* in general.yaml. networkRouter.dnsZone and
clusterProxy.clusterName are defaulted in parser.hydrateNetBirdDefaults
(from the netbird DNS base and cluster.name respectively). The *Enabled
flags and HasNetBirdOperatorValues are precomputed in getTemplateValues,
so this template needs no nil-guarding boolean logic.
*/ -}}
{{- if .HasNetBirdOperatorValues }}
netbird-operator:
{{- if .NetBirdManagementURL }}
  managementURL: {{ .NetBirdManagementURL | quote }}
{{- end }}
{{- if .NetBirdNetworkRouterEnabled }}
  networkRouter:
    enabled: true
    dnsZone: {{ .NetBird.NetworkRouter.DNSZone | quote }}
    replicas: {{ .NetBird.NetworkRouter.Replicas }}
{{- end }}
{{- with .NetBird }}
{{- if gt (len .NetworkResources) 0 }}
  networkResources:
{{- range .NetworkResources }}
    - name: {{ .Name | quote }}
      namespace: {{ .Namespace | quote }}
      service: {{ .Service | quote }}
      groups:
{{- range .Groups }}
        - {{ . | quote }}
{{- end }}
{{- end }}
{{- end }}
{{- end }}
{{- if .NetBirdClusterProxyEnabled }}
  clusterProxy:
    enabled: true
    clusterName: {{ .NetBird.ClusterProxy.ClusterName | quote }}
{{- with .NetBird.ClusterProxy }}
{{- if gt (len .RBAC) 0 }}
    rbac:
{{- range .RBAC }}
      - group: {{ .Group | quote }}
        clusterRole: {{ .ClusterRole | quote }}
{{- end }}
{{- end }}
{{- end }}
{{- end }}
{{- end }}
