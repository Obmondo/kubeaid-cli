---
ccm-hetzner:
  {{- /* robot.enabled controls the Hetzner Robot controller. Enable it only
       when bare-metal nodes are present (bare-metal or hybrid mode).
       Must explicitly set false for hcloud — the chart defaults robot to true. */ -}}
  {{- if (or (eq .HetznerConfig.Mode "bare-metal") (eq .HetznerConfig.Mode "hybrid")) }}
  robot:
    enabled: true
  {{- else }}
  robot:
    enabled: false
  {{- end }}

  {{- /* In a hybrid cluster ccm-hetzner handles bare-metal (Robot) nodes only;
       ccm-hcloud owns LoadBalancers and the service controller. Scope ccm-hetzner
       to the node-lifecycle controllers so the two CCMs don't fight over Services.
       For pure bare-metal mode ccm-hetzner is the only CCM, so no scoping. */ -}}
  {{- if (eq .HetznerConfig.Mode "hybrid") }}
  args:
    controllers: "cloud-node,cloud-node-lifecycle"
  {{- end }}

  {{- /* networking.enabled tells HCCM to manage Hetzner Cloud Routes for pod-to-pod
       connectivity via the private Hetzner Network. Applies to any VPN-connected cluster
       (vpn-type or workload fronted by a VPN). Mutually exclusive with robot: bare-metal
       and hybrid clusters never run as VPN. */ -}}
  {{- if (or (eq .ClusterConfig.Type "vpn") (and (eq .ClusterConfig.Type "workload") .HetznerConfig.HCloudVPNCluster)) }}
  networking:
    enabled: true
  {{- end }}

  {{- /* Mirror the additionalTolerations the postKubeadm helm block sets at bootstrap,
       so ArgoCD's desired state matches and does not strip the toleration on the
       next sync. */ -}}
  additionalTolerations:
    - key: node.kubernetes.io/not-ready
      operator: Exists
      effect: NoSchedule
