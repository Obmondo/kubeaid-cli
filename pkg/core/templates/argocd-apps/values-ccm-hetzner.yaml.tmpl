---
{{- if (or (eq .HetznerConfig.Mode "hcloud") (eq .HetznerConfig.Mode "hybrid")) }}
ccm-hetzner:
  extraEnvVars:
    - name: HCLOUD_LOAD_BALANCERS_NETWORK_ZONE
      value: {{ .HetznerConfig.HCloud.Zone }}

    {{- if (and (eq .ClusterConfig.Type "workload") .HetznerConfig.VPNCluster) }}

    # Disables the public interface of the Load Balancer by default.
    - name: HCLOUD_LOAD_BALANCERS_DISABLE_PUBLIC_NETWORK
      value: true

    # Configures the Load Balancer to use the private IP for Load Balancer server targets by
    # default.
    - name: HCLOUD_LOAD_BALANCERS_USE_PRIVATE_IP
      value: true
    {{- end }}

{{- end }}
