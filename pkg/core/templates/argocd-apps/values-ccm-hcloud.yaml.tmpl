{{- /* $privateNodes: HCloud nodes that live on the private Hetzner Network
     with no public interface (vpn / workload behind a VPN). The single
     public CP node is the exception — public IPv4, no private network. */ -}}
{{- $privateNodes := (and (or (eq .ClusterConfig.Type "vpn") (and (eq .ClusterConfig.Type "workload") .HetznerConfig.HCloudVPNCluster)) (not .HCloudSingleNodePublic)) -}}
---
ccm-hetzner:
  {{- /* nameOverride drives the Deployment, ServiceAccount, and RBAC resource names.
       "ccm-hcloud" keeps the two CCM instances distinct in a hybrid cluster where
       both ccm-hcloud and ccm-hetzner run in kube-system. */}}
  nameOverride: ccm-hcloud

  {{- /* ccm-hcloud owns HCloud nodes; Robot support must be off so it doesn't also
       try to initialise bare-metal nodes (ccm-hetzner does that). */}}
  robot:
    enabled: false

  {{- /* LB env is always relevant for ccm-hcloud — it is the CCM that manages
       HCloud LoadBalancers for all modes that include HCloud nodes. */}}
  env:
    HCLOUD_LOAD_BALANCERS_NETWORK_ZONE:
      value: {{ .HetznerConfig.HCloud.Zone }}

    {{- /* Two independent knobs:
           DISABLE_PUBLIC_NETWORK (no public LB frontend) is workload-behind-
           VPN only — a vpn cluster's own LBs (Keycloak / NetBird ingress)
           must keep a public frontend.
           USE_PRIVATE_IP (LB target attachment) covers all private nodes —
           they have no public interface to attach over. */}}
    {{- if (and (eq .ClusterConfig.Type "workload") .HetznerConfig.HCloudVPNCluster) }}
    HCLOUD_LOAD_BALANCERS_DISABLE_PUBLIC_NETWORK:
      value: "true"
    {{- end }}
    {{- if $privateNodes }}
    HCLOUD_LOAD_BALANCERS_USE_PRIVATE_IP:
      value: "true"
    {{- end }}

  {{- /* networking.enabled: hccm manages private-network pod Routes and sets
       InternalIP on HCloud nodes. Needed for private nodes and for hybrid
       (HCloud CPs reach bare-metal workers over the private network; without
       InternalIP the apiserver can't reach kubelets). The single public node
       has no private network — its InternalIP comes from the public
       interface. */}}
  {{- if (or $privateNodes (eq .HetznerConfig.Mode "hybrid")) }}
  networking:
    enabled: true
  {{- end }}

  {{- /* Mirror the additionalTolerations the postKubeadm helm block sets at bootstrap,
       so ArgoCD's desired state matches and does not strip the toleration on the
       next sync. The not-ready/Exists/NoSchedule toleration lets ccm-hcloud schedule
       on nodes before they have been initialised (the chicken-and-egg window where
       CCM itself must run to clear node.cloudprovider.kubernetes.io/uninitialized). */}}
  additionalTolerations:
    - key: node.kubernetes.io/not-ready
      operator: Exists
      effect: NoSchedule
