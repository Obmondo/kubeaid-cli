---
hcloud-cloud-controller-manager:
  additionalTolerations:
    - key: node.kubernetes.io/not-ready
      operator: Exists
      effect: NoSchedule

  env:
    HCLOUD_LOAD_BALANCERS_NETWORK_ZONE:
      value: {{ .HetznerConfig.HCloud.Zone }}

    {{/* When using a VPN cluster, we'll be using Hetzner Network, and thus can have internal LBs.
         By default, apps will be exposed to internally.
         When needed, sysadmins can explicitly specify (using annotations) that they want to expose
         an app to the public internet. */}}
    {{- if (and (eq .ClusterConfig.Type "workload") .HetznerConfig.HCloudVPNCluster) }}

    # Disables the public interface of the Load Balancer by default.
    HCLOUD_LOAD_BALANCERS_DISABLE_PUBLIC_NETWORK:
      value: "true"

    # Configures the Load Balancer to use the private IP for Load Balancer server targets by
    # default.
    HCLOUD_LOAD_BALANCERS_USE_PRIVATE_IP:
      value: "true"
    {{- end }}

  {{- if or (eq .ClusterConfig.Type "vpn") (and (eq .ClusterConfig.Type "workload") .HetznerConfig.HCloudVPNCluster) }}
  networking:
    enabled: true
    network:
      valueFrom:
        secretKeyRef:
          name: cloud-credentials
          key: network
  {{- end }}
