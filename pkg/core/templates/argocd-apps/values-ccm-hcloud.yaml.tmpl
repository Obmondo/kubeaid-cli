---
hcloud-cloud-controller-manager:
  additionalTolerations:
    - key: node.kubernetes.io/not-ready
      operator: Exists
      effect: NoSchedule

  env:
    HCLOUD_LOAD_BALANCERS_NETWORK_ZONE:
      value: {{ .HetznerConfig.HCloud.Zone }}

    {{- /* VPN-cluster nodes sit on a private Hetzner Network with no public IP,
         so the CCM must reach LB backends (the nodes) by their private IP.
         Applies to a vpn-type cluster and to a workload cluster fronted by a
         VPN — same condition as the networking block below. */ -}}
    {{- if or (eq .ClusterConfig.Type "vpn") (and (eq .ClusterConfig.Type "workload") .HetznerConfig.HCloudVPNCluster) }}

    # Use the private IP of Load Balancer server targets (the nodes) by default.
    HCLOUD_LOAD_BALANCERS_USE_PRIVATE_IP:
      value: "true"
    {{- end }}

    {{- /* A workload cluster fronted by a VPN exposes its apps internally by
         default; sysadmins opt an app onto the public internet via Service
         annotations. A vpn-type cluster is the VPN itself — its Keycloak /
         NetBird ingress LBs must stay public — so this default is not set
         there. */ -}}
    {{- if (and (eq .ClusterConfig.Type "workload") .HetznerConfig.HCloudVPNCluster) }}

    # Disable the public interface of the Load Balancer by default.
    HCLOUD_LOAD_BALANCERS_DISABLE_PUBLIC_NETWORK:
      value: "true"
    {{- end }}

  {{- if or (eq .ClusterConfig.Type "vpn") (and (eq .ClusterConfig.Type "workload") .HetznerConfig.HCloudVPNCluster) }}
  networking:
    enabled: true
    network:
      valueFrom:
        secretKeyRef:
          name: cloud-credentials
          key: network
  {{- end }}
