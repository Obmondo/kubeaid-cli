{{- /* $preCreatedLB: kubeaid-cli pre-created the control-plane LB (vpn /
     workload behind a VPN) and CAPH consumes it instead of creating one.
     The single public CP node is excluded — it has no control-plane LB at
     all. Nil-safe for non-Hetzner renders. */ -}}
{{- $preCreatedLB := (and .HetznerConfig (not .HCloudSingleNodePublic) (or (eq .ClusterConfig.Type "vpn") (and (eq .ClusterConfig.Type "workload") .HetznerConfig.HCloudVPNCluster))) -}}
global:
  clusterName: {{ .ClusterConfig.Name }}
  {{- /* Names HCloud MachineTemplates after a hash of their spec, so a changed
       machineType rotates the name and ClusterAPI rolls the machines. CAPI
       compares only the template's name, never its contents, so with the fixed
       legacy name an instance-type change never rolls. Changing only replicas
       leaves the name alone, and the control plane scales out instead. */}}
  machineTemplateRotation: {{ .ClusterConfig.MachineTemplateRotation }}
  {{- if .ObmondoConfig }}
  customerid: {{ .ObmondoConfig.CustomerID }}
  {{- end }}
  kubernetes:
    version: {{ .K8sVersion }}
  kubeaid:
    repo: {{ .KubeaidFork.URL }}
    # Pinned for the in-node `git clone` in postKubeadmCommands. Keeps
    # Cilium / CCM installs on the control-plane on the same chart
    # snapshot kubeaid-cli rendered locally, instead of letting them
    # drift to whatever the fork's default branch happens to be at
    # node bootstrap time.
    version: {{ .KubeaidFork.Version }}
  {{- /* kubeaid-storagectl is only fetched by the Hetzner bare-metal
       KubeadmConfig / KubeadmControlPlane templates. Skip emitting it
       for hcloud-only (or other-provider) clusters so the rendered
       values file doesn't carry config the chart never reads. */ -}}
  {{- if and .HetznerConfig (or (eq .HetznerConfig.Mode "bare-metal") (eq .HetznerConfig.Mode "hybrid")) }}
  # Pinned so each bare-metal node downloads the kubeaid-storagectl binary
  # that matches the kubeaid-cli release that bootstrapped it. Empty on
  # dev builds, which makes the chart fall back to `latest`.
  kubeaidStoragectl:
    version: {{ .KubeaidStoragectlVersion }}
  {{- end }}
  kubeaidConfig:
    repo: {{ .KubeaidConfigFork.URL }}
  additionalUsers: {{- .AdditionalUsers | toYAML | nindent 4 }}

{{- if .AWSConfig }}
provider:
  aws: true

aws:
  # Currently, hostNetworking must be set to true.
  # Otherwise, during the Kubernetes version upgrade process, when the control-plane nodes get
  # restarted, AWS CAPA errors out, complaining that :
  #
  #     NoCredentialProviders: no valid providers in chain. Deprecated.
  useHostNetwork: true
  secretName: cloud-credentials
  sshKeyName: {{ .AWSConfig.SSHKeyName }}
  region: {{ .AWSConfig.Region }}
  bastion:
    enabled: {{ .AWSConfig.BastionEnabled }}
  vpc:
    cidrBlock: 10.14.0.0/22
  pods:
    cidrBlock: 10.244.0.0/16
  controlPlane:
    loadBalancer:
      loadBalancerType: nlb
      scheme: {{ .AWSConfig.ControlPlane.LoadBalancerScheme }}
    region: {{ .AWSConfig.Region }}
    replicas: {{ .AWSConfig.ControlPlane.Replicas }}
    instanceType: {{ .AWSConfig.ControlPlane.InstanceType }}
    ami:
      id: {{ .AWSConfig.ControlPlane.AMI.ID }}
    {{- if .ClusterConfig.APIServer }}
    apiServer:
      extraArgs: {{- .ClusterConfig.APIServer.ExtraArgs | toYaml | nindent 8 }}
      extraVolumes: {{- .ClusterConfig.APIServer.ExtraVolumes | toYaml | nindent 8 }}
      files: {{- .ClusterConfig.APIServer.Files | toYaml | nindent 8 }}
    {{- end }}
  nodeGroups: {{- .AWSConfig.NodeGroups | toYaml | nindent 4 }}
{{- end }}

{{- if .AzureConfig }}
provider:
  azure: true

azure:
  tenantID: {{ .AzureConfig.TenantID }}
  subscriptionID: {{ .AzureConfig.SubscriptionID }}
  location: {{ .AzureConfig.Location }}
  resourceGroup: {{ .ClusterConfig.Name }}

  sshPublicKey: {{ .AzureConfig.SSHPublicKey }}

  userAssignedIdentity:
    name: capi
    clientID: {{ .CAPIUAMIClientID }}

  serviceAccountIssuer:
    url: {{ .ServiceAccountIssuerURL }}

  canonicalUbuntuImage: {{- .AzureConfig.CanonicalUbuntuImage | toIndentYAML 2 | nindent 4 }}

  controlPlane: {{- .AzureConfig.ControlPlane | toIndentYAML 2 | nindent 4 }}

  nodeGroups: {{- .AzureConfig.NodeGroups | toIndentYAML 2 | nindent 4 }}
{{- end }}

{{- if .HetznerConfig }}
provider:
  hetzner: true

hetzner:
  mode: {{ .HetznerConfig.Mode }}
  {{- if .HCloudSingleNodePublic }}
  {{- /* Single public control-plane node: no private HCloud network, no NAT.
       network.type=public flips the CP HCloudMachineTemplate to a public IPv4
       and drops the HetznerCluster hcloudNetwork block. */}}
  network:
    type: public
  {{- end }}

  sshKeyPair:
    name: {{ .HetznerConfig.SSHKeyPair.Name }}

  {{- if (or (eq .HetznerConfig.Mode "hcloud") (eq .HetznerConfig.Mode "hybrid")) }}
  hcloud:
    zone: {{ .HetznerConfig.HCloud.Zone }}
    imageName: {{ .HetznerConfig.HCloud.ImageName }}
    cidrBlock: {{ .HetznerConfig.HCloud.HetznerNetwork.CIDR }}
    subnetCidrBlock: {{ .HetznerConfig.HCloud.HetznerNetwork.HCloudServersSubnetCIDR }}
  {{- end }}

  {{- if (or (eq .HetznerConfig.Mode "bare-metal") (eq .HetznerConfig.Mode "hybrid")) }}
  bareMetal:
    wipeDisks: {{ .HetznerConfig.BareMetal.WipeDisks }}
    installImage:
      imagePath: {{ .HetznerConfig.BareMetal.InstallImage.ImagePath }}
      vg0:
        size: {{ .HetznerConfig.BareMetal.InstallImage.VG0.Size }}
        rootVolumeSize: {{ .HetznerConfig.BareMetal.InstallImage.VG0.RootVolumeSize }}
    {{- if .HetznerConfig.BareMetal.VSwitch }}
    vSwitch:
      vlanID: {{ .HetznerConfig.BareMetal.VSwitch.VLANID }}
    {{- end }}
  {{- end }}

  controlPlane:
    regions: {{- .HetznerConfig.ControlPlane.Regions | toIndentYAML 2 | nindent 6 }}

    {{- /* Operator kube-apiserver customization, hydrated by the parser
         into ClusterConfig.APIServer from the typed cluster.apiServer
         block: the OIDC AuthenticationConfiguration (file + --authentication-
         config flag + host-path mount) and audit logging. The hetzner chart
         maps extraArgs (a map, converted to CAPI v1beta2's {name,value} list),
         extraVolumes, and files onto the KubeadmControlPlane. Without emitting
         this block the rendered AuthenticationConfiguration never reaches the
         apiserver and OIDC logins 401. The AWS branch emits the equivalent;
         this is the Hetzner parity.

         Close this comment plainly — do NOT add a trailing
         whitespace-trim marker. The trim would eat the newline after the
         regions list and weld apiServer onto the last entry, rendering a
         broken "- hel1apiServer:". */}}
    apiServer:
      extraArgs: {{- .ClusterConfig.APIServer.ExtraArgs | toYAML | nindent 8 }}
      extraVolumes: {{- .ClusterConfig.APIServer.ExtraVolumes | toYAML | nindent 8 }}
      files: {{- .ClusterConfig.APIServer.Files | toYAML | nindent 8 }}

    {{- /* Apiserver cert SANs — operator-supplied controlPlane.extraCertSANs,
         on every Hetzner mode. The chart merges these with endpoint.host into
         kubeadm's apiServer.certSANs. The mesh-name SAN (kubernetes.<dnsZone>)
         is intentionally omitted: the NetBird kube-apiserver proxy makes it
         unnecessary. Close this comment plainly — no trailing trim — so
         extraCertSANs keeps its own line. */}}
    {{- if .ControlPlaneExtraCertSANs }}
    extraCertSANs: {{- .ControlPlaneExtraCertSANs | toYAML | nindent 6 }}
    {{- end }}

    {{- /* Bare-metal control-plane endpoint — sourced from
         cloud.hetzner.controlPlane.bareMetal.endpoint.host
         (typically a Robot failover IP managed by
         hetzner-failover-script). Without this, HetznerCluster
         reports ControlPlaneEndpointNotSet ("disabled LoadBalancer
         and not yet provided ControlPlane endpoint") and every
         downstream reconcile — KubeadmConfig, HBMHost, Machine —
         stalls waiting for Cluster infrastructure to be Ready.
         The hcloud/hybrid branch below still owns its own endpoint
         emission for the VPN-cluster pre-created LB shape. */ -}}
    {{- if eq .HetznerConfig.Mode "bare-metal" }}
    endpoint:
      host: {{ .ControlPlaneEndpoint | quote }}
    {{- end }}

    {{- /* apiserver endpoint, rendered whenever kubeaid-cli knows it up
         front: the lone public CP node's api DNS name, or the pre-created
         control-plane LB (vpn / workload behind a VPN — CAPH consumes that
         LB instead of creating one; privateIP / bootstrapPublicIP surface
         its runtime info). Workload-not-on-VPN renders neither: CAPH owns
         the LB lifecycle. */ -}}
    {{- if (or (eq .HetznerConfig.Mode "hcloud") (eq .HetznerConfig.Mode "hybrid")) }}
    {{- if (or .HCloudSingleNodePublic $preCreatedLB) }}
    endpoint:
      host: {{ .ControlPlaneEndpoint }}
    {{- end }}
    {{- if $preCreatedLB }}
    loadBalancer:
      privateIP: {{ .ControlPlaneLBPrivateIP }}
      {{- if .ControlPlaneLBBootstrapPublicIP }}
      bootstrapPublicIP: {{ .ControlPlaneLBBootstrapPublicIP }}
      {{- end }}
    {{- end }}
    {{- end }}

    {{- /* Handling control-plane in Hetzner bare-metal. */ -}}
    {{- if eq .HetznerConfig.Mode "bare-metal" }}
    bareMetal: {{- .HetznerConfig.ControlPlane.BareMetal | toIndentYAML 2 | nindent 6 }}

    {{- /* Handling control-plane in HCloud. Render the fields the
         chart's schema actually permits — machineType, replicas,
         loadBalancer.{enabled,region}. Don't dump the whole
         HCloudControlPlane struct via toIndentYAML: it includes
         LoadBalancer.{Endpoint, ExtraCertSANs} which the chart
         schema rejects (chart's loadBalancer is just enabled +
         region; the endpoint hostname goes at
         controlPlane.endpoint.host above).

         For VPN-cluster bootstraps where kubeaid-cli pre-created
         the LB itself, force loadBalancer.enabled=false here so
         CAPH doesn't ALSO try to create a load-balancer; the
         operator's pre-created LB + endpoint.host above are what
         we want CAPH to consume. */ -}}
    {{- else }}
    hcloud:
      machineType: {{ .HetznerConfig.ControlPlane.HCloud.MachineType }}
      replicas: {{ .HetznerConfig.ControlPlane.HCloud.Replicas }}
      {{- if .CoturnFloatingIPs }}
      floatingIPs:
        {{- range .CoturnFloatingIPs }}
        - {{ . }}
        {{- end }}
      {{- end }}
      loadBalancer:
        {{- /* enabled toggles CAPH creating its own control-plane LB. Forced
             off for the single public node (no LB exists at all) and when
             kubeaid-cli pre-created the LB (CAPH consumes that one via
             endpoint.host above). */}}
        {{- if (or .HCloudSingleNodePublic $preCreatedLB) }}
        enabled: false
        {{- else }}
        enabled: {{ .HetznerConfig.ControlPlane.HCloud.LoadBalancer.Enabled }}
        {{- end }}
        region: {{ .HetznerConfig.ControlPlane.HCloud.LoadBalancer.Region }}
    {{- end }}

  nodeGroups: {{- .HetznerConfig.NodeGroups | toIndentYAML 2 | nindent 4 }}
{{- end }}
