git:
  sshUsername: {{ .SSHUsername }}
  useSSHAgent: {{ .UseSSHAgent }}
{{- if and (not .UseSSHAgent) .SSHKeyPath }}
  privateKeyFilePath: {{ .SSHKeyPath }}
{{- end }}
{{- if .GitKnownHosts }}
  knownHosts:
{{- range .GitKnownHosts }}
    - "{{ . }}"
{{- end }}
{{- end }}

forkURLs:
  kubeaid:
    url: {{ .KubeaidForkURL }}
    version: {{ .KubeaidVersion }}
  kubeaidConfig:
    url: {{ .KubeaidConfigForkURL }}
    directory: {{ .KubeaidConfigDir }}

cluster:
  type: {{ .ClusterType }}
  name: {{ .ClusterName }}
  k8sVersion: {{ .K8sVersion }}
  enableAuditLogging: {{ .EnableAuditLogging }}
{{- if .ACMEEmail }}
  acmeEmail: {{ .ACMEEmail }}
{{- end }}
  apiServer:
    extraArgs: {}
    extraVolumes: []
    files: []
{{- if .EnableOIDC }}
    oidc:
      issuerUrl: {{ .OIDCIssuerURL }}
      clientId: {{ .OIDCClientID }}
{{- else }}
    # Optional. Set cluster.apiServer.oidc to enable OIDC on
    # kube-apiserver. Issuer URL is probed at bootstrap.
    #
    # oidc:
    #   issuerUrl: https://keycloak.example/realms/clusters
    #   clientId:  kubernetes-{{ .ClusterName }}
{{- end }}
{{- if .KeycloakDNS }}
  keycloak:
    mode: {{ .KeycloakMode }}
    dns: {{ .KeycloakDNS }}
{{- if .KeycloakRealm }}
    realm: {{ .KeycloakRealm }}
{{- end }}
{{- end }}
{{- if eq .ClusterType "vpn" }}
  netbird:
    dns: {{ .NetBirdDNS }}
{{- end }}
  argoCD:
    deployKeys:
{{- if .KubeaidIsSSH }}
      kubeaid:
        privateKeyFilePath: {{ .KubeaidConfigDeployKeyPath }}
{{- end }}
      kubeaidConfig:
        privateKeyFilePath: {{ .KubeaidConfigDeployKeyPath }}
{{- if .KubePrometheusVersion }}

kubePrometheus:
  version: {{ .KubePrometheusVersion }}
{{- end }}

cloud:
{{- if eq .CloudProvider "aws" }}
  aws:
    region: {{ .AWSRegion }}
    sshKeyName: {{ .AWSSSHKeyName }}
    bastionEnabled: true
    controlPlane:
      loadBalancerScheme: internet-facing
      replicas: {{ .AWSCPReplicas }}
      instanceType: {{ .AWSCPInstanceType }}
      ami:
        id: {{ .AWSAMIID }}
{{- end }}
{{- if eq .CloudProvider "azure" }}
  azure:
    tenantID: {{ .AzureTenantID }}
    subscriptionID: {{ .AzureSubscriptionID }}
    location: {{ .AzureLocation }}
    storageAccount: {{ .AzureStorageAccount }}
    controlPlane:
      loadBalancerType: Public
      diskSizeGB: {{ .AzureCPDiskSizeGB }}
      vmSize: {{ .AzureCPVMSize }}
      replicas: {{ .AzureCPReplicas }}
{{- end }}
{{- if eq .CloudProvider "hetzner" }}
  hetzner:
    mode: {{ .HetznerMode }}
    sshKeyPair:
      name: {{ .HetznerSSHKeyName }}
{{- if .UseSSHAgent }}
      useSSHAgent: true
{{- else }}
      privateKeyFilePath: {{ .HetznerSSHKeyPath }}
{{- end }}
{{- if eq .HetznerMode "hcloud" }}
    hcloud:
      zone: {{ .HetznerHCloudZone }}
      imageName: ubuntu-24.04
      hetznerNetwork:
        cidr: "10.0.0.0/16"
        hcloudServersSubnetCIDR: "10.0.0.0/24"
    controlPlane:
      hcloud:
        machineType: {{ .HetznerCPMachineType }}
        replicas: {{ .HetznerCPReplicas }}
        loadBalancer:
          enabled: true
          region: {{ .HetznerLBRegion }}
{{- if eq .ClusterType "vpn" }}
          endpoint: {{ .ControlPlaneEndpoint }}
{{- else }}
          endpoint:
{{- end }}
      regions:
        - {{ .HetznerRegion }}
    nodeGroups:
      hcloud: []
{{- end }}
{{- if eq .HetznerMode "hybrid" }}
    hcloud:
      zone: {{ .HetznerHCloudZone }}
      imageName: ubuntu-24.04
      hetznerNetwork:
        cidr: "10.0.0.0/16"
        hcloudServersSubnetCIDR: "10.0.0.0/24"
    bareMetal:
      wipeDisks: false
      installImage:
        imagePath: /root/.oldroot/nfs/images/Ubuntu-2404-noble-amd64-base.tar.gz
        vg0:
          size: 80
          rootVolumeSize: 50
      vSwitch:
        name: {{ .HetznerVSwitchName }}
        vlanID: {{ .HetznerVSwitchVLANID }}
        subnetCIDRBlock: "{{ .HetznerVSwitchSubnetCIDR }}"
    controlPlane:
      hcloud:
        machineType: {{ .HetznerCPMachineType }}
        replicas: {{ .HetznerCPReplicas }}
        loadBalancer:
          enabled: true
          region: {{ .HetznerLBRegion }}
{{- if eq .ClusterType "vpn" }}
          endpoint: {{ .ControlPlaneEndpoint }}
{{- else }}
          endpoint:
{{- end }}
      regions:
        - {{ .HetznerRegion }}
    nodeGroups:
      hcloud: []
      bareMetal:
        - name: {{ .HetznerBMNodeGroupName }}
          bareMetalHosts:
{{- range $i, $id := .HetznerBMNodeGroupServerIDs }}
            # Robot main IP: {{ index $.HetznerBMServerPublicIPs $id }}
            - serverID: "{{ $id }}"
              privateIP: {{ index $.HetznerBMNodeGroupPrivateIPs $i }}
{{- end }}
{{- end }}
{{- if eq .HetznerMode "bare-metal" }}
    bareMetal:
      wipeDisks: false
      installImage:
        imagePath: /root/.oldroot/nfs/images/Ubuntu-2404-noble-amd64-base.tar.gz
        vg0:
          size: 80
          rootVolumeSize: 50
      vSwitch:
        name: {{ .HetznerVSwitchName }}
        vlanID: {{ .HetznerVSwitchVLANID }}
        subnetCIDRBlock: "{{ .HetznerVSwitchSubnetCIDR }}"
    controlPlane:
      bareMetal:
        endpoint:
          isFailoverIP: {{ .HetznerBMEndpointIsFailoverIP }}
          host: {{ .HetznerBMEndpointHost }}
        bareMetalHosts:
{{- range $i, $id := .HetznerBMCPServerIDs }}
          # Robot main IP: {{ index $.HetznerBMServerPublicIPs $id }}
          - serverID: "{{ $id }}"
            privateIP: {{ index $.HetznerBMCPPrivateIPs $i }}
{{- end }}
      regions:
{{- range .HetznerBMCPRegions }}
        - {{ . }}
{{- end }}
    nodeGroups:
      bareMetal:
        - name: {{ .HetznerBMNodeGroupName }}
          bareMetalHosts:
{{- range $i, $id := .HetznerBMNodeGroupServerIDs }}
            # Robot main IP: {{ index $.HetznerBMServerPublicIPs $id }}
            - serverID: "{{ $id }}"
              privateIP: {{ index $.HetznerBMNodeGroupPrivateIPs $i }}
{{- end }}
{{- end }}
{{- end }}
{{- if eq .CloudProvider "bare-metal" }}
  bare-metal:
    ssh:
      port: {{ .BareMetalSSHPort }}
    controlPlane:
      endpoint:
        host: {{ .BareMetalEndpointHost }}
        port: {{ .BareMetalEndpointPort }}
      hosts: []
{{- end }}
{{- if eq .CloudProvider "local" }}
  local: {}
{{- end }}
{{ if .Obmondo }}
obmondo:
{{- if .Obmondo.CustomerID }}
  customerID: {{ .Obmondo.CustomerID }}
{{- end }}
  monitoring: {{ .Obmondo.Monitoring }}
  certPath: {{ .Obmondo.CertPath }}
  keyPath: {{ .Obmondo.KeyPath }}
  teleportAgent: false
{{- end }}
