{{- /* Every secret value is rendered with `printf %q` so that YAML
       metacharacters (#, :, leading -, &, *, !, etc.) in random
       cloud-provider tokens don't get interpreted by the parser.
       Hetzner Robot usernames in particular can start with '#',
       which YAML would otherwise treat as a comment and turn
       `user: #abc` into `user:` (blank value) — failing the
       Robot.User notblank validator at bootstrap. */ -}}
{{- if eq .CloudProvider "aws" }}
{{- if .AWSAccessKeyID }}
aws:
  accessKeyID: {{ printf "%q" .AWSAccessKeyID }}
  secretAccessKey: {{ printf "%q" .AWSSecretAccessKey }}
  sessionToken: {{ printf "%q" .AWSSessionToken }}
{{- end }}
{{- end }}
{{- if eq .CloudProvider "azure" }}
azure:
  clientID: {{ printf "%q" .AzureClientID }}
  clientSecret: {{ printf "%q" .AzureClientSecret }}
{{- end }}
{{- /* apiToken is required for every Hetzner mode (CAPH's controller
       startup calls getAndValidateHCloudToken before any of its 5
       reconcilers — including HetznerBareMetalMachine — can run, and
       kubeaid-cli's vSwitch-to-HCloud-Network bridging at bootstrap
       calls the HCloud API directly). The outer guard avoids rendering
       a bare `hetzner:` key with no children when both inputs are empty
       (theoretical, but YAML-invalid). */ -}}
{{- if and (eq .CloudProvider "hetzner") (or .HetznerAPIToken .HetznerRobotUser) }}
hetzner:
{{- if .HetznerAPIToken }}
  apiToken: {{ printf "%q" .HetznerAPIToken }}
{{- end }}
{{- if and .HetznerRobotUser .HetznerRobotPassword }}
  robot:
    user: {{ printf "%q" .HetznerRobotUser }}
    password: {{ printf "%q" .HetznerRobotPassword }}
{{- end }}
{{- end }}
{{- if eq .KeycloakMode "external" }}
keycloak:
  netBirdBackendClientSecret: {{ printf "%q" .NetBirdBackendClientSecret }}
{{- end }}
